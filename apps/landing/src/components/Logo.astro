---
// Rinciku brand lockup — mark (rounded square + three descending bars) + wordmark.
// Brand colors are fixed (lime #9ae600 + forest green #35530e), ported from the
// web app's LogoMark / favicon so it matches exactly.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<span class:list={['logo', className]}>
  <svg
    viewBox='0 0 32 32'
    width='28'
    height='28'
    role='img'
    aria-label='Rinciku'
    class='mark'
  >
    <rect x='0' y='0' width='32' height='32' rx='8' fill='#9ae600'></rect>
    <rect
      x='5'
      y='8'
      width='22'
      height='5'
      rx='2.5'
      fill='#35530e'
      opacity='0.93'></rect>
    <rect
      x='5'
      y='16'
      width='15'
      height='5'
      rx='2.5'
      fill='#35530e'
      opacity='0.65'></rect>
    <rect
      x='5'
      y='24'
      width='9'
      height='5'
      rx='2.5'
      fill='#35530e'
      opacity='0.37'></rect>
  </svg>
  <span class='word'>Rinciku</span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-foreground);
  }
  .mark {
    flex: none;
  }
  .word {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
</style>
