---
import type { Copy } from '../i18n/types';
interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const { problem } = copy;
---

<section class="section">
  <div class="inner">
    <header class="head">
      <h2 class="title">{problem.heading}</h2>
      <p class="sub">{problem.subhead}</p>
    </header>
    <ul class="grid">
      {
        problem.items.map((item) => (
          <li class="card">
            <h3 class="card-title">{item.title}</h3>
            <p class="card-body">{item.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section {
    padding: 4rem 1.5rem;
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .head {
    max-width: 44rem;
  }
  .title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .sub {
    margin-top: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
  }
  .grid {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  .card {
    padding: 1.5rem;
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }
  .card-title {
    font-weight: 600;
    font-size: 1.0625rem;
  }
  .card-body {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }
</style>
