---
import Logo from './Logo.astro';
import type { Copy } from '../i18n/types';
interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const { compare } = copy;
---

<section class='section'>
  <div class='inner'>
    <header class='head'>
      <h2 class='title'>{compare.heading}</h2>
      <p class='sub'>{compare.subhead}</p>
    </header>

    <div class='table-wrap'>
      <table class='table'>
        <thead>
          <tr>
            <th class='feat-col'><span class='sr-only'>Feature</span></th>
            <th class='rinciku-col'>
              <Logo class='th-logo' />
            </th>
            <th class='typical-col'>{compare.colTypical}</th>
          </tr>
        </thead>
        <tbody>
          {
            compare.rows.map((row) => (
              <tr>
                <th scope='row' class='feat'>
                  {row.feature}
                </th>
                <td class='rinciku'>
                  <span class='check' aria-hidden='true'>
                    <svg
                      viewBox='0 0 24 24'
                      width='13'
                      height='13'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='3'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                    >
                      <path d='M20 6 9 17l-5-5' />
                    </svg>
                  </span>
                  {row.rinciku}
                </td>
                <td class='typical'>{row.typical}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 4rem 1.5rem;
  }
  .inner {
    max-width: 60rem;
    margin: 0 auto;
  }
  .head {
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }
  .title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .sub {
    margin-top: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .table-wrap {
    margin-top: 2.5rem;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background-color: var(--color-card);
  }
  .table {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }
  thead th {
    padding: 1.125rem 1.25rem;
    text-align: left;
    font-weight: 600;
    vertical-align: bottom;
  }
  .typical-col {
    color: var(--color-muted-foreground);
    font-weight: 500;
  }
  .rinciku-col {
    border-top-right-radius: 0;
  }
  .th-logo {
    transform: translateY(2px);
  }
  tbody tr {
    border-top: 1px solid var(--color-border);
  }
  .feat {
    padding: 1rem 1.25rem;
    text-align: left;
    font-weight: 500;
    color: var(--color-foreground);
  }
  .rinciku,
  .typical {
    padding: 1rem 1.25rem;
  }
  .rinciku {
    font-weight: 600;
    background-color: color-mix(in oklch, var(--color-primary) 7%, transparent);
  }
  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    margin-right: 0.4rem;
    vertical-align: -0.2rem;
    border-radius: 9999px;
    background-color: var(--color-primary);
    color: var(--color-primary-foreground);
  }
  .typical {
    color: var(--color-muted-foreground);
  }
</style>
