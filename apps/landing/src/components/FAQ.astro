---
import type { Copy } from '../i18n/types';
interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const { faq } = copy;
---

<section id="faq" class="section">
  <div class="inner">
    <header class="head">
      <h2 class="title">{faq.heading}</h2>
      <p class="sub">{faq.subhead}</p>
    </header>
    <div class="list">
      {
        faq.items.map((item) => (
          <details class="item">
            <summary class="q">
              <span>{item.q}</span>
              <svg class="chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="a">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding: 4rem 1.5rem;
  }
  .inner {
    max-width: 48rem;
    margin: 0 auto;
  }
  .head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .sub {
    margin-top: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
  }
  .list {
    display: grid;
    gap: 0.75rem;
  }
  .item {
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 0 1.25rem;
  }
  .q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.125rem 0;
    font-weight: 600;
    font-size: 1.0625rem;
    cursor: pointer;
    list-style: none;
  }
  .q::-webkit-details-marker {
    display: none;
  }
  .chev {
    flex: none;
    color: var(--color-muted-foreground);
    transition: transform 0.2s ease;
  }
  .item[open] .chev {
    transform: rotate(180deg);
  }
  .a {
    margin: 0;
    padding: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
    max-width: 42rem;
  }
</style>
