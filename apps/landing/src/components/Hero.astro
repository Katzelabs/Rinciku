---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import aiChat from '../assets/screenshots/ai-chat.png';
import type { Copy } from '../i18n/types';
import { signUpUrl } from '../i18n/utils';

interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const { hero } = copy;
---

<section class="hero">
  <div class="glow" aria-hidden="true"></div>
  <div class="inner">
    <span class="eyebrow">
      <span class="dot" aria-hidden="true"></span>
      {hero.badge}
    </span>
    <h1 class="headline">
      {hero.headline}
      <span class="accent">{hero.headlineAccent}</span>
    </h1>
    <p class="subhead">{hero.subhead}</p>
    <div class="ctas">
      <Button href={signUpUrl} size="lg">{hero.cta}</Button>
    </div>
    <p class="note">{hero.ctaNote}</p>

    <div class="frame">
      <div class="frame-bar" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <Image src={aiChat} alt={hero.screenshotAlt} widths={[640, 960, 1280]} sizes="(min-width: 1024px) 960px, 100vw" loading="eager" class="shot" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 4rem 1.5rem 3rem;
  }
  .glow {
    position: absolute;
    top: -12rem;
    left: 50%;
    transform: translateX(-50%);
    width: 60rem;
    max-width: 120%;
    height: 40rem;
    background: radial-gradient(
      50% 50% at 50% 50%,
      color-mix(in oklch, var(--color-primary) 30%, transparent) 0%,
      transparent 70%
    );
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }
  .inner {
    position: relative;
    z-index: 1;
    max-width: 60rem;
    margin: 0 auto;
    text-align: center;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    background-color: color-mix(in oklch, var(--color-primary) 16%, transparent);
    color: var(--color-primary-foreground);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background-color: var(--color-primary);
  }
  .headline {
    margin: 1.25rem auto 0;
    max-width: 20ch;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }
  .accent {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-primary-foreground);
    padding: 0 0.3em;
    border-radius: 0.2em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .subhead {
    margin: 1.25rem auto 0;
    max-width: 44rem;
    font-size: clamp(1rem, 2.4vw, 1.1875rem);
    line-height: 1.6;
    color: var(--color-muted-foreground);
  }
  .ctas {
    margin-top: 1.75rem;
  }
  .note {
    margin-top: 0.875rem;
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
  }
  .frame {
    margin: 3rem auto 0;
    max-width: 62rem;
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    box-shadow:
      0 1px 0 0 color-mix(in oklch, var(--color-foreground) 4%, transparent),
      0 30px 60px -25px color-mix(in oklch, var(--color-foreground) 30%, transparent);
    overflow: hidden;
  }
  .frame-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-background);
  }
  .frame-bar span {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 9999px;
    background-color: var(--color-border);
  }
  .shot {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
