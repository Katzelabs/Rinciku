---
import Logo from './Logo.astro';
import type { Copy, Locale } from '../i18n/types';
import { githubUrl, privacyHref, termsHref, contactUrl } from '../i18n/utils';
interface Props {
  locale: Locale;
  copy: Copy;
}
const { locale, copy } = Astro.props;
const { footer } = copy;
const year = new Date().getFullYear();
---

<footer class='footer'>
  <div class='inner'>
    <div class='brand-col'>
      <Logo />
      <p class='tagline'>{footer.tagline}</p>
    </div>
    <div class='meta'>
      <p class='made'>{footer.madeWith}</p>
      <nav class='links' aria-label='Footer'>
        <a href={privacyHref(locale)}>{footer.privacy}</a>
        <span class='dot' aria-hidden='true'>·</span>
        <a href={termsHref(locale)}>{footer.terms}</a>
        <span class='dot' aria-hidden='true'>·</span>
        <a href={contactUrl}>{footer.contact}</a>
        <span class='dot' aria-hidden='true'>·</span>
        <a
          class='gh'
          href={githubUrl}
          target='_blank'
          rel='noopener noreferrer'
        >
          <svg
            viewBox='0 0 24 24'
            width='15'
            height='15'
            fill='currentColor'
            aria-hidden='true'
          >
            <path
              d='M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.4-1.27.74-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.28 5.69.41.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z'
            ></path>
          </svg>
          {footer.github}
        </a>
      </nav>
      <p class='copy'>© {year} Rinciku. {footer.rights}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 1.5rem;
    background-color: var(--color-background);
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .inner {
      grid-template-columns: 1fr auto;
      align-items: start;
    }
  }
  .tagline {
    margin-top: 0.875rem;
    max-width: 26rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 768px) {
    .meta {
      align-items: flex-end;
      text-align: right;
    }
  }
  .made {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    max-width: 26rem;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) {
    .links {
      justify-content: flex-end;
    }
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
  }
  .links a:hover {
    color: var(--color-primary-foreground);
  }
  .dot {
    color: var(--color-muted-foreground);
  }
  .copy {
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
  }
</style>
