---
import type { Copy } from '../i18n/types';
interface Props {
  copy: Copy;
}
const { copy } = Astro.props;
const { howItWorks } = copy;
---

<section class="section">
  <div class="inner">
    <header class="head">
      <h2 class="title">{howItWorks.heading}</h2>
      <p class="sub">{howItWorks.subhead}</p>
    </header>
    <ol class="steps">
      {
        howItWorks.steps.map((step, i) => (
          <li class="step">
            <span class="num" aria-hidden="true">{i + 1}</span>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section {
    padding: 4rem 1.5rem;
  }
  .inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .head {
    max-width: 44rem;
  }
  .title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .sub {
    margin-top: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
  }
  .steps {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    counter-reset: step;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }
  .step {
    position: relative;
    padding: 1.75rem 1.5rem;
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
  }
  .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-primary-foreground);
    background-color: var(--color-primary);
    border-radius: 9999px;
  }
  .step-title {
    margin-top: 1rem;
    font-weight: 600;
    font-size: 1.125rem;
  }
  .step-body {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted-foreground);
  }
</style>
