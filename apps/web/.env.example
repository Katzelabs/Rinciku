# Local development (default): values come from `supabase status` after `supabase start`.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Remote project (when ready, replace the two values above):
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=<publishable key (sb_publishable_...) from Project Settings → API Keys>

# Cloudflare Turnstile (captcha widget on the web auth forms). Web-only
# client-side gate at launch (ClickUp 86ey87u65): set this to render the widget
# and block submit until solved. Server-side [auth.captcha] stays OFF until the
# mobile app serves a widget too — do not enable it in the Supabase dashboard.
# Prod: site key from the Cloudflare Turnstile dashboard (domain-scoped).
# Local dev: Cloudflare's always-pass test key below works.
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
