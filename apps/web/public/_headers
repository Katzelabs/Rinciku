# Cloudflare Workers static-assets headers. Files in public/ are copied to the
# build output root, so this lands at dist/_headers where the platform reads it.
# Prod-only — the Vite dev server ignores this file.
#
# CSP notes (all verified against the code):
# - connect-src: Supabase (pinned to the prod project ref — verified against
#   the deployed bundle's VITE_SUPABASE_URL), plus open.er-api.com (FX rates,
#   packages/core/fx.ts) and cloudflareinsights.com (Web Analytics beacon
#   POST). The LLM goes through the ai-chat edge function — no openrouter.ai
#   here. wss: covers realtime if ever enabled.
# - script-src: static.cloudflareinsights.com — Cloudflare auto-injects the
#   Web Analytics beacon script into served HTML. challenges.cloudflare.com —
#   the Turnstile captcha loader (widget is env-gated; allowance is inert
#   until VITE_TURNSTILE_SITE_KEY is set).
# - frame-src: challenges.cloudflare.com — the Turnstile challenge iframe.
# - img-src: attachment previews use short-lived signed URLs on the Supabase
#   host; data:/blob: cover local previews and AI-chat inline data: images.
# - style-src 'unsafe-inline': required — Radix/shadcn set inline style attrs.
# - font-src 'self': Figtree is bundled via @fontsource-variable (no CDN).

# Fingerprinted build assets — cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Security headers for every response.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://uyxkzkvomcavxxqkreqq.supabase.co; font-src 'self'; connect-src 'self' https://uyxkzkvomcavxxqkreqq.supabase.co wss://uyxkzkvomcavxxqkreqq.supabase.co https://open.er-api.com https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
