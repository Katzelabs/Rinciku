# Cloudflare Workers static-assets headers. Files in public/ are copied to the
# build output root, so this lands at dist/_headers where the platform reads it.
# Prod-only — the Vite dev server ignores this file.
#
# CSP notes (all verified against the code):
# - connect-src: only Supabase is called from the browser (the LLM goes through
#   the ai-chat edge function — no openrouter.ai here). wss: covers realtime if
#   ever enabled. Tighten *.supabase.co to the exact project ref at launch.
# - img-src: attachment previews use short-lived signed URLs on the Supabase
#   host; data:/blob: cover local previews and AI-chat inline data: images.
# - style-src 'unsafe-inline': required — Radix/shadcn set inline style attrs.
# - font-src 'self': Figtree is bundled via @fontsource-variable (no CDN).

# Fingerprinted build assets — cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Security headers for every response.
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.supabase.co; font-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'
