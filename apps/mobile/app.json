{
  "expo": {
    "name": "Rinciku",
    "slug": "rinciku",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rinciku",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "ios": {
      "icon": {
        "light": "./assets/images/ios-icon-light.png",
        "dark": "./assets/images/ios-icon-dark.png",
        "tinted": "./assets/images/ios-icon-tinted.png"
      },
      "bundleIdentifier": "com.rinciku.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rinciku.app",
      "adaptiveIcon": {
        "backgroundColor": "#1D1D16",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "backgroundColor": "#F2F2EA",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#0A0A08"
          }
        }
      ],
      "expo-localization",
      "@react-native-vector-icons/material-design-icons",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rinciku uses your photos to attach receipts to your transactions.",
          "cameraPermission": "Rinciku uses your camera to photograph receipts for your transactions."
        }
      ],
      "expo-secure-store",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
