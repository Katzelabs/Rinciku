         isTabBarHidden: Boolean,
     ) {
         bottomNavigationView.isVisible = !isTabBarHidden
+        if (isTabBarHidden) {
+            // PATCH(rinciku): React Native's TouchTargetHelper hit-tests by frame
+            // only and never checks visibility, so the GONE bar keeps its
+            // laid-out frame and keeps swallowing every React touch in its
+            // strip (native-handling views like EditText still work, so the
